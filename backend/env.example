# Configurações do Servidor
PORT=3000
NODE_ENV=development
API_URL=http://localhost:3000/api

# Configurações do Banco de Dados
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gtsystem?schema=public"

# Configurações de JWT
JWT_SECRET=sua_chave_secreta_super_segura_aqui
JWT_REFRESH_SECRET=outra_chave_secreta_super_segura_aqui
JWT_ACCESS_EXPIRATION=3600 # 1 hora em segundos
JWT_REFRESH_EXPIRATION=604800 # 7 dias em segundos

# Configurações de Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Configurações de E-mail
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=seu_email@example.com
SMTP_PASS=sua_senha_aqui
EMAIL_FROM=noreply@gtsystem.com
CLIENT_URL=http://localhost:5173

# Configurações de Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5 # em MB

# Configurações de Log
LOG_LEVEL=info 